# ContextBridge Backend — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to source control.

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://contextbridge:your_password@localhost:5432/contextbridge

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.contextbridge.ai

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["chrome-extension://*","http://localhost:3000"]
