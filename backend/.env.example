# ContextOS Backend Environment
# Copy to .env and fill in credentials.

# --- Neo4j AuraDB (required) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# --- LLM Providers (via LiteLLM) ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Demo Mode (set True to bypass LLM + Neo4j for presentations) ---
MOCK_MODE=False
